python -c "import sys; import numpy as np; import pandas as pd; df = pd.read_csv(sys.argv[1]); x = df.x.values; y = df.y.values; coefs = np.polyfit(x, y, 4); print('=== 四次多项式拟合结果 ==='); print('拟合公式：y = a4*x^4 + a3*x^3 + a2*x^2 + a1*x + a0'); print('系数：'); print(f'a4 = {coefs[0]:.6f}'); print(f'a3 = {coefs[1]:.6f}'); print(f'a2 = {coefs[2]:.6f}'); print(f'a1 = {coefs[3]:.6f}'); print(f'a0 = {coefs[4]:.6f}'); print(''); print('完整拟合式：'); print(f'y = {coefs[0]:.4f}x^4 + {coefs[1]:.4f}x^3 + {coefs[2]:.4f}x^2 + {coefs[3]:.4f}x + {coefs[4]:.4f}')" "fit_data.csv"